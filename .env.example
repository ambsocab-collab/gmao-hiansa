# ============================================================================
# Environment Variables Template - gmao-hiansa
# GMAO - Gestión de Mantenimiento Asistido por Ordenador
# ============================================================================
# IMPORTANT: Copy this file to .env.local and fill in actual values
# DO NOT commit .env.local to version control (it contains secrets)

# ============================================================================
# Application Environment
# ============================================================================
NODE_ENV=development
# Values: development, production, test

# ============================================================================
# Database Configuration (Neon PostgreSQL - Serverless)
# ============================================================================
# Production: Get from Neon Console (https://console.neon.tech)
# Development: Use local PostgreSQL or Neon dev branch
DATABASE_URL="postgresql://user:password@host/database_name?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database_name?sslmode=require"

# Notes:
# - DATABASE_URL: Prisma ORM connection string (with pooling)
# - DIRECT_URL: Direct connection for migrations (without pooling)
# - Use ?sslmode=require for Neon PostgreSQL

# ============================================================================
# NextAuth.js Authentication (v4.24.7)
# ============================================================================
NEXTAUTH_URL=http://localhost:3000
# Production: Set to your production domain (e.g., https://your-domain.com)

NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"
# IMPORTANT: Generate a secure secret for production!
# Use: openssl rand -base64 32

# Session Configuration
NEXTAUTH_SESSION_MAX_AGE=28800
# 8 hours in seconds (8 * 60 * 60 = 28800)
# Sessions expire after 8 hours of inactivity

# ============================================================================
# Application URLs
# ============================================================================
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1

# ============================================================================
# Server-Sent Events (SSE) Configuration
# ============================================================================
SSE_HEARTBEAT_INTERVAL=30000
# Heartbeat every 30 seconds (30000ms)
# Production: Keep at 30s for optimal performance

SSE_RECONNECTION_TIMEOUT=30000
# Auto-reconnect if connection lost (30 seconds)

# ============================================================================
# Testing Environment Variables
# ============================================================================
# Only used during automated testing
TEST_ENV=test
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminpassword123

# ============================================================================
# External Services (Mock in Development/Test)
# ============================================================================
EMAIL_SERVICE_MOCK=true
PDF_SERVICE_MOCK=true

# ============================================================================
# Observability & Monitoring
# ============================================================================
# Logging level for application (debug, info, warn, error)
LOG_LEVEL=debug

# Performance tracking threshold (queries slower than this are logged)
PERFORMANCE_THRESHOLD_MS=1000

# ============================================================================
# CI/CD Configuration
# ============================================================================
COVERAGE=true
COVERAGE_REPORTER=html
COVERAGE_OUTPUT_DIR=coverage

PLAYWRIGHT_BROWSER_PATH=chromium

VITEST_WATCH=1

# ============================================================================
# Development Notes
# ============================================================================
# 1. Local development: Copy this file to .env.local and configure
# 2. Testing: Use the TEST_* credentials above
# 3. Production: Configure ALL variables with real values in Vercel dashboard
# 4. Security: NEVER commit .env.local to version control
# 5. Database: Use Neon PostgreSQL for Vercel compatibility
# 6. Auth: Use NextAuth v4.24.7 (NOT v5 beta)
# 7. Sessions: 8-hour timeout enforced by maxAge
# 8. Browsers: Chrome and Edge only (Chromium-based)
# ============================================================================

