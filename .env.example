# Environment Variables for Testing
# gmao-hiansa (GMAO - Gestión de Mantenimiento Asistido por Ordenador)

# Test Environment
TEST_ENV=test
NODE_ENV=test

# Base URLs (default to local development)
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1

# Database (Neon PostgreSQL - serverless, Vercel-compatible)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="test-secret-change-in-production-min-32-chars"

# Auth Test Credentials
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminpassword123

# SSE (Server-Sent Events) Testing
SSE_HEARTBEAT_INTERVAL=1000 # Faster heartbeat for tests (1s instead of 30s)

# External Services (mock in tests)
EMAIL_SERVICE_MOCK=true
PDF_SERVICE_MOCK=true

# Coverage
COVERAGE=true
COVERAGE_REPORTER=html
COVERAGE_OUTPUT_DIR=coverage

# Playwright
PLAYWRIGHT_BROWSER_PATH chromium

# Vitest
VITEST_PROVIDERS=[])
