// prisma/schema.prisma
// GMAO HiRock/Ultra - Database Schema
// Story 0.2: Database Schema con Jerarquía 5 Niveles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELS CORE: User & Capability (PBAC)
// ============================================

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  name               String
  phone              String?
  forcePasswordReset Boolean   @default(false) @map("force_password_reset")
  deleted            Boolean   @default(false) // Soft delete (Story 1.1)
  lastLogin          DateTime? @map("last_login") // Last login timestamp (Story 1.1)
  skills             String[]  @default([]) // Story 3.3: Habilidades del técnico (eléctrica, mecánica, etc.)
  ubicacion          String?   @map("ubicacion") // Story 3.3: Ubicación de trabajo (Planta HiRock, Planta Ultra, Taller, Almacén)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  userCapabilities     UserCapability[]
  userTags             UserTag[] // Story 1.3: Classification tags (visual organization only)
  workOrderAssignments WorkOrderAssignment[]
  failureReports       FailureReport[]       @relation("FailureReports")
  workOrderComments    WorkOrderComment[]    @relation("WorkOrderComments") // AC7
  activityLogs         ActivityLog[] // Story 1.1: User activity tracking
  auditLogs            AuditLog[] // Story 1.1: Audit trail for critical actions

  @@index([email])
  @@index([deleted]) // For filtering soft-deleted users (Story 1.1)
  @@index([createdAt])
  @@index([ubicacion]) // Story 3.3: Para filtrar por ubicación
  @@map("users")
}

model Capability {
  id          String  @id @default(cuid())
  name        String  @unique // enum inglés: can_create_failure_report, etc.
  label       String // castellano: "Crear Reporte de Avería"
  description String?

  // Relations
  userCapabilities UserCapability[]

  @@map("capabilities")
}

model UserCapability {
  userId       String   @map("userId")
  capabilityId String   @map("capabilityId")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([userId, capabilityId])
  @@index([userId]) // Para buscar capabilities de un usuario
  @@map("userCapabilities")
}

// Story 1.1: Activity Log for user actions (login, profile_update, password_change)
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("userId")
  action    String // login, profile_update, password_change, capability_changed
  metadata  Json? // Additional context for the action
  timestamp DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp]) // For querying user activity history
  @@map("activityLogs")
}

// Story 1.1: Audit Log for critical actions (user_created, user_deleted, etc.)
model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("userId") // Admin who performed the action
  action    String // user_created, user_deleted, capability_changed, etc.
  targetId  String?  @map("target_id") // ID of the affected user/entity
  metadata  Json? // Additional context
  timestamp DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp]) // For querying admin audit history
  @@map("auditLogs")
}

// Story 1.3: Classification Tags (visual organization, NO capabilities)
model Tag {
  id          String   @id @default(cuid())
  name        String   @unique // "Operario", "Técnico", "Supervisor"
  color       String // Hex color WCAG AA compliant
  description String?  // Optional description
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userTags UserTag[]

  @@index([name])
  @@map("tags")
}

// Story 1.3: Join table para User ↔ Tag (muchos a muchos)
model UserTag {
  userId     String   @map("userId")
  tagId      String   @map("tagId")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@index([userId]) // Para buscar etiquetas de un usuario
  @@index([tagId])  // Para buscar usuarios con una etiqueta
  @@map("userTags")
}

// ============================================
// JERARQUÍA DE 5 NIVELES
// ============================================

enum Division {
  HIROCK
  ULTRA
}

model Planta {
  id         String   @id @default(cuid())
  name       String
  code       String   @unique
  division   Division
  created_at DateTime @default(now())

  // Relations
  lineas Linea[]

  @@index([code])
  @@map("plantas")
}

model Linea {
  id         String   @id @default(cuid())
  name       String
  code       String
  planta_id  String
  created_at DateTime @default(now())

  // Relations
  planta  Planta   @relation(fields: [planta_id], references: [id], onDelete: Cascade)
  equipos Equipo[]

  @@unique([planta_id, code])
  @@index([planta_id])
  @@map("lineas")
}

enum EquipoEstado {
  OPERATIVO
  AVERIADO
  EN_REPARACION
  RETIRADO
  BLOQUEADO
}

model Equipo {
  id               String       @id @default(cuid())
  name             String
  code             String
  linea_id         String
  estado           EquipoEstado @default(OPERATIVO)
  ubicacion_actual String?
  created_at       DateTime     @default(now())

  // Relations
  linea             Linea              @relation(fields: [linea_id], references: [id], onDelete: Cascade)
  equipo_components EquipoComponente[] // Muchos-a-muchos vía EquipoComponente
  work_orders       WorkOrder[]
  failureReports    FailureReport[]

  @@unique([linea_id, code])
  @@index([linea_id])
  @@index([name]) // Para búsqueda predictiva <200ms
  @@index([linea_id, estado]) // Para filtrar por línea y estado (Kanban)
  @@index([estado]) // Para filtrar todos los equipos por estado
  @@map("equipos")
}

model Componente {
  id         String   @id @default(cuid())
  name       String
  code       String
  created_at DateTime @default(now())

  // Relations
  equipo_components EquipoComponente[] // Muchos-a-muchos vía EquipoComponente
  repuestos         Repuesto[]

  @@index([code])
  @@map("componentes")
}

model EquipoComponente {
  equipo_id     String
  componente_id String
  created_at    DateTime @default(now())

  // Relations
  equipo     Equipo     @relation(fields: [equipo_id], references: [id], onDelete: Cascade)
  componente Componente @relation(fields: [componente_id], references: [id], onDelete: Cascade)

  @@id([equipo_id, componente_id])
  @@map("equipo_componentes")
}

model Repuesto {
  id               String   @id @default(cuid())
  name             String
  code             String
  componente_id    String
  stock            Int      @default(0)
  stock_minimo     Int      @default(0)
  ubicacion_fisica String?
  created_at       DateTime @default(now())

  // Relations
  componente  Componente      @relation(fields: [componente_id], references: [id], onDelete: Cascade)
  usedIn      UsedRepuesto[]  @relation("RepuestoUsage") // AC4

  @@index([componente_id])
  @@index([code])
  @@map("repuestos")
}

// ============================================
// MODELOS DE OPERACIONES
// ============================================

enum WorkOrderTipo {
  PREVENTIVO
  CORRECTIVO
}

enum WorkOrderEstado {
  PENDIENTE
  ASIGNADA
  EN_PROGRESO
  PENDIENTE_REPUESTO
  PENDIENTE_PARADA
  REPARACION_EXTERNA
  COMPLETADA
  DESCARTADA
}

enum WorkOrderPrioridad {
  BAJA
  MEDIA
  ALTA
}

model WorkOrder {
  id                  String            @id @default(cuid())
  numero              String            @unique
  tipo                WorkOrderTipo
  estado              WorkOrderEstado   @default(PENDIENTE)
  prioridad           WorkOrderPrioridad @default(MEDIA)
  descripcion         String
  equipo_id           String
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  completed_at        DateTime?
  verificacion_at     DateTime?         @map("verificacion_at") // AC6: Verificación por operario
  parent_work_order_id String?          @unique @map("parent_work_order_id")

  // Relations
  equipo         Equipo                @relation(fields: [equipo_id], references: [id], onDelete: Cascade)
  assignments    WorkOrderAssignment[]
  failure_report FailureReport?        @relation(fields: [failure_report_id], references: [id])
  parent_work_order   WorkOrder?        @relation("WorkOrderHierarchy", fields: [parent_work_order_id], references: [id])
  child_work_orders   WorkOrder[]       @relation("WorkOrderHierarchy")
  comments            WorkOrderComment[]    @relation("WorkOrderComments") // AC7
  photos              WorkOrderPhoto[]      @relation("WorkOrderPhotos") // AC8
  usedRepuestos       UsedRepuesto[]        @relation("UsedRepuestos") // AC4

  failure_report_id String? @unique

  @@index([equipo_id])
  @@index([numero]) // Para búsqueda rápida
  @@index([estado]) // Para filtrar por estado (Kanban)
  @@index([prioridad]) // Para filtrar por prioridad (Story 2.3 AC6)
  @@index([equipo_id, estado]) // Para joins con filtro de estado
  @@index([created_at]) // Para ordenamiento temporal
  @@map("work_orders")
}

enum AssignmentRole {
  TECNICO
  PROVEEDOR
}

// Story 3.3: Modelo para Proveedores Externos
model Provider {
  id           String   @id @default(cuid())
  name         String
  email        String?  @map("email")
  phone        String?  @map("phone")
  services     String[] // Tipos de servicio: ["eléctrica", "mecánica", "hidráulica", "neumática", "electrónica"]
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  assignments WorkOrderAssignment[]

  @@index([name])
  @@index([active])
  @@map("providers")
}

model WorkOrderAssignment {
  id            String         @id @default(cuid())
  work_order_id String
  userId        String?        // Story 3.3: Ahora opcional para soportar asignación de proveedores
  providerId    String?        @map("provider_id") // Story 3.3: Para asignación de proveedores
  role          AssignmentRole
  created_at    DateTime       @default(now())

  // Relations
  work_order WorkOrder @relation(fields: [work_order_id], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([work_order_id, userId, providerId]) // Story 3.3: Compound unique constraint
  @@index([userId]) // Para buscar OTs asignadas a un usuario
  @@index([work_order_id]) // Para buscar asignaciones de una OT
  @@index([providerId]) // Story 3.3: Para buscar OTs asignadas a un proveedor
  @@map("workOrderAssignments")
}

enum FailureReportEstado {
  NUEVO
  RECIBIDO
  AUTORIZADO
  EN_PROGRESO
  COMPLETADO
  CONVERTIDO
  DESCARTADO
}

model FailureReport {
  id            String              @id @default(cuid())
  numero        String              @unique
  descripcion   String
  tipo          String              @default("avería") // "avería" o "reparación" (NFR-S10)
  fotoUrl       String?             @map("foto_url")
  equipoId      String              @map("equipo_id")
  estado        FailureReportEstado @default(NUEVO)
  reportadoPor  String              @map("reportado_por")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  // Relations
  equipo       Equipo     @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  reporter     User       @relation("FailureReports", fields: [reportadoPor], references: [id], onDelete: Cascade)
  workOrder    WorkOrder?

  @@index([equipoId])
  @@index([numero]) // Para búsqueda rápida
  @@index([estado]) // Para filtrar por estado
  @@index([equipoId, estado]) // Para joins con filtro de estado
  @@index([reportadoPor]) // Para reportes de un usuario
  @@index([createdAt]) // Para ordenamiento temporal
  @@map("failureReports")
}

// ============================================
// MODELOS DE STORY 3.2: GESTIÓN DE OTS ASIGNADAS
// ============================================

// AC7: Comentarios en OTs
model WorkOrderComment {
  id            String   @id @default(cuid())
  work_order_id String
  user_id       String
  texto         String   @db.Text
  created_at    DateTime @default(now())

  // Relations
  work_order WorkOrder @relation("WorkOrderComments", fields: [work_order_id], references: [id], onDelete: Cascade)
  user       User      @relation("WorkOrderComments", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([work_order_id])
  @@index([created_at])
  @@map("work_order_comments")
}

// AC8: Fotos de OTs (antes/después)
enum PhotoTipo {
  ANTES
  DESPUES
}

model WorkOrderPhoto {
  id            String     @id @default(cuid())
  work_order_id String
  tipo          PhotoTipo
  url           String     // Vercel Blob URL
  created_at    DateTime   @default(now())

  // Relations
  work_order WorkOrder @relation("WorkOrderPhotos", fields: [work_order_id], references: [id], onDelete: Cascade)

  @@index([work_order_id])
  @@index([tipo])
  @@map("work_order_photos")
}

// AC4: Repuestos usados en OTs
model UsedRepuesto {
  id            String   @id @default(cuid())
  work_order_id String
  repuesto_id   String
  cantidad      Int      // Cantidad usada
  created_at    DateTime @default(now())

  // Relations
  work_order WorkOrder @relation("UsedRepuestos", fields: [work_order_id], references: [id], onDelete: Cascade)
  repuesto   Repuesto @relation("RepuestoUsage", fields: [repuesto_id], references: [id], onDelete: Cascade)

  @@index([work_order_id])
  @@index([repuesto_id])
  @@map("used_repuestos")
}

// Test-only model for capturing SSE events in E2E tests
model SSETestEvent {
  id        String   @id @default(cuid())
  name      String
  data      Json
  capturedAt DateTime @default(now())
  
  @@map("sse_test_events")
}
