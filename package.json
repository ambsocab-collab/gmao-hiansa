{
  "name": "gmao-hiansa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "cross-env PLAYWRIGHT_TEST=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "npx vitest run --environment=jsdom",
    "test:watch": "npx vitest --watch --environment=jsdom",
    "test:unit": "npx vitest run tests/unit --environment=jsdom",
    "test:integration": "npx vitest run tests/integration --environment=jsdom",
    "test:all": "npx vitest run tests/unit tests/integration --environment=jsdom",
    "test:coverage": "npx vitest run --coverage --environment=jsdom",
    "test:ui": "npx vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:p0": "playwright test -g \"P0-\"",
    "test:e2e:story-1.1": "playwright test tests/e2e/story-1.1-*.spec.ts",
    "test:e2e:story-1.1:reporter": "playwright test tests/e2e/story-1.1-*.spec.ts --reporter=html",
    "test:ci": "npm run test:e2e --workers=4 && npm run test:coverage",
    "test:perf": "npm run test:perf:login && npm run test:perf:asset-search && npm run test:perf:create-ot",
    "test:perf:login": "k6 run tests/performance/baseline/login-load-test.js",
    "test:perf:asset-search": "k6 run tests/performance/baseline/asset-search-load-test.js",
    "test:perf:create-ot": "k6 run tests/performance/baseline/create-ot-load-test.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:reset": "prisma db push --force-reset",
    "db:seed": "prisma db seed",
    "db:seed:10k-equipos": "tsx prisma/seed-10k-equipos.ts",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-vitest": "^0.5.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^1.0.0",
    "vitest-dom": "^0.1.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "tests/**/*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ],
    "app/**/*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ],
    "lib/**/*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ],
    "middleware.ts": [
      "eslint --fix",
      "tsc --noEmit"
    ]
  }
}
